# Local + Vercel environment template for VoltSolar
# On Vercel: Project Settings → Environment Variables → add for Production (and Preview)

# --- Client (exposed to the browser; must start with VITE_) ---
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# --- Optional: protect Vercel Cron keep-alive (/api/keep-alive) ---
# If set, Vercel sends Authorization: Bearer <CRON_SECRET> on scheduled runs.
# Generate any long random string and add it in Vercel → Environment Variables.
# CRON_SECRET="your-long-random-secret"

# --- Server only (contact form / ZeptoMail; NEVER use VITE_ prefix) ---
# Required: Send Mail Token from ZeptoMail → Agent → SMTP/API
ZEPTOMAIL_TOKEN="Zoho-enczapikey PASTE_YOUR_TOKEN_HERE"
ZEPTOMAIL_FROM_EMAIL="voltsolar@learnwithchris.app"
ZEPTOMAIL_FROM_NAME="VoltSolar"
CONTACT_TO_EMAIL="frohitedigitals@gmail.com"

# Optional: comma-separated browser origins allowed to call /api/contact
# CONTACT_ALLOWED_ORIGINS="https://voltsolar.learnwithchris.app,http://localhost:3000"

# Optional: only if your ZeptoMail account is in another region (EU/IN/CN)
# ZEPTOMAIL_API_URL="https://api.zeptomail.com/v1.1/email"
